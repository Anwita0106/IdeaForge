# Copy this file to .env (for local dev) and/or .env.production (for builds
# you intend to deploy) and point it at your running backend.
#
# Local dev (matches `uvicorn main:app --reload` default):
VITE_API_BASE_URL=http://localhost:8000

# Production example (replace with your actual Render/Railway URL):
# VITE_API_BASE_URL=https://ideaforge-api.onrender.com
