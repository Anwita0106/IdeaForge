# Copy this file to .env and fill in your own values.
# Every external API key below is OPTIONAL - if you leave one blank,
# IdeaForge's built-in heuristic engine fills the gap automatically.

ENVIRONMENT=development

# --- Database ---------------------------------------------------------
# Local Postgres:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ideaforge
#
# Supabase (Project Settings -> Database -> Connection string -> URI):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Neon (Dashboard -> Connection Details):
# DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ideaforge

# --- CORS ----------------------------------------------------------------
# Comma separated list of frontend origins allowed to call this API.
# Use * only for local development.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Demo data -------------------------------------------------------------
# If true, the app inserts a few demo ideas into an empty database on startup.
SEED_DEMO_DATA=false

# --- External APIs (all optional) ----------------------------------------
# Crunchbase Enterprise API key: https://data.crunchbase.com/docs/using-the-api
CRUNCHBASE_API_KEY=

# Product Hunt developer token: https://api.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_TOKEN=

# Google Custom Search: https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Clearbit company enrichment key: https://clearbit.com/docs
CLEARBIT_API_KEY=
